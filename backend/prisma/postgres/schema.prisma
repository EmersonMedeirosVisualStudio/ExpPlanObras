datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Tenant {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique
  cnpj      String   @unique
  companyEmail String?
  companyWhatsapp String?
  link      String?
  googleMapsLink String?
  street    String?
  number    String?
  neighborhood String?
  city      String?
  state     String?
  cep       String?
  latitude  String?
  longitude String?
  status    String   @default("TEMPORARY")
  subscriptionStatus String @default("TRIAL") // legado
  trialEndsAt DateTime? // legado
  trialExpiresAt DateTime?
  paidUntil DateTime?
  billingProvider String?
  billingPlan String?
  billingExternalId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     TenantUser[]
  obras     Obra[]
  etapas    Etapa[]
  custos    Custo[]
  documentos Documento[]
  tarefas   Tarefa[]
  responsaveisTecnicos ResponsavelTecnico[]
  history   TenantHistoryEntry[]
  subscriptions Subscription[]
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  cpf       String   @unique
  name      String?
  password  String
  whatsapp  String?
  address   String?
  location  String?
  oauthProvider String?
  oauthId String?
  isSystemAdmin Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenants   TenantUser[]
  tenantHistoryEntries TenantHistoryEntry[]
}

model TenantHistoryEntry {
  id        Int      @id @default(autoincrement())
  tenantId  Int
  source    String
  action    String?
  message   String
  actorUserId Int?
  createdAt DateTime @default(now())

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actorUser User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  attachments TenantHistoryAttachment[]

  @@index([tenantId])
  @@index([actorUserId])
}

model TenantHistoryAttachment {
  id      Int @id @default(autoincrement())
  entryId Int
  url     String?
  filename String?
  mimeType String?
  data     Bytes?

  entry   TenantHistoryEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@index([entryId])
}

model Subscription {
  id        Int      @id @default(autoincrement())
  tenantId  Int
  plan      String
  status    String
  startedAt DateTime
  expiresAt DateTime?
  paymentProvider String?
  paymentId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model TenantUser {
  id        Int      @id @default(autoincrement())
  tenantId  Int
  userId    Int
  role      String   @default("USER")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([tenantId, userId])
  @@index([userId])
  @@index([tenantId])
}

model Obra {
  id        Int      @id @default(autoincrement())
  name      String
  description String?
  type      String   @default("PARTICULAR")
  status    String   @default("NAO_INICIADA")
  street       String?
  number       String?
  neighborhood String?
  city         String?
  state        String?
  latitude     String?
  longitude    String?
  valorPrevisto Decimal?
  tenantId  Int
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  etapas    Etapa[]
  custos    Custo[]
  documentos Documento[]
  tarefas   Tarefa[]
  medicoes  Medicao[]
  pagamentos Pagamento[]
  responsaveis ResponsavelObra[]
  @@index([tenantId])
}

model Etapa {
  id        Int      @id @default(autoincrement())
  name      String
  obraId    Int
  obra      Obra     @relation(fields: [obraId], references: [id])
  tenantId  Int
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  startDate DateTime?
  endDate   DateTime?
  status    String   @default("PENDENTE")
  @@index([tenantId])
  @@index([obraId])
}

model Custo {
  id        Int      @id @default(autoincrement())
  description String
  amount    Decimal
  date      DateTime
  obraId    Int
  obra      Obra     @relation(fields: [obraId], references: [id])
  tenantId  Int
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  @@index([tenantId])
  @@index([obraId])
}

model Documento {
  id        Int      @id @default(autoincrement())
  name      String
  url       String
  type      String
  obraId    Int
  obra      Obra     @relation(fields: [obraId], references: [id])
  tenantId  Int
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  uploadedAt DateTime @default(now())
  @@index([tenantId])
  @@index([obraId])
}

model Tarefa {
  id        Int      @id @default(autoincrement())
  title     String
  description String?
  status    String   @default("PENDENTE")
  dueDate   DateTime?
  obraId    Int
  obra      Obra     @relation(fields: [obraId], references: [id])
  tenantId  Int
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  @@index([tenantId])
  @@index([obraId])
}

model ResponsavelTecnico {
  id        Int      @id @default(autoincrement())
  name      String
  professionalTitle String?
  crea      String?
  cpf       String?
  email     String?
  phone     String?
  tenantId  Int
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  obras     ResponsavelObra[]
  @@index([tenantId])
}

model ResponsavelObra {
  id        Int      @id @default(autoincrement())
  obraId    Int
  obra      Obra     @relation(fields: [obraId], references: [id])
  responsavelId Int
  responsavel ResponsavelTecnico @relation(fields: [responsavelId], references: [id])
  role      String
  startDate DateTime @default(now())
  endDate   DateTime?
  notes     String?
  @@index([obraId])
  @@index([responsavelId])
}

model Medicao {
  id        Int      @id @default(autoincrement())
  obraId    Int
  obra      Obra     @relation(fields: [obraId], references: [id])
  date      DateTime
  description String
  amount    Decimal
  percentage Decimal?
  createdAt DateTime @default(now())
  pagamentos Pagamento[]
  @@index([obraId])
}

model Pagamento {
  id        Int      @id @default(autoincrement())
  obraId    Int
  obra      Obra     @relation(fields: [obraId], references: [id])
  medicaoId Int?
  medicao   Medicao? @relation(fields: [medicaoId], references: [id])
  date      DateTime
  amount    Decimal
  documentNumber String?
  notes     String?
  createdAt DateTime @default(now())
  @@index([obraId])
  @@index([medicaoId])
}
