  escopoDescricao String?
  ownerUserId  Int?
  auditorLiderUserId Int?
  dataInicioPlanejada DateTime?
  dataFimPlanejada DateTime?
  dataInicioReal DateTime?
  dataFimReal   DateTime?
  opiniaoFinal  String?
  ratingFinal   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner        User?    @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)
  auditorLider User?    @relation(fields: [auditorLiderUserId], references: [id], onDelete: SetNull)
  itensEscopo  GrcAuditoriaItemEscopo[]
  achados      GrcAchado[]

  @@unique([tenantId, codigo])
  @@index([tenantId, statusAuditoria])
}

model GrcAuditoriaItemEscopo {
  id          Int      @id @default(autoincrement())
  tenantId     Int
  auditoriaId  Int
  tipoItem     String
  referenciaId Int?
  descricao    String?

  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  auditoria    GrcAuditoria @relation(fields: [auditoriaId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([auditoriaId])
}

model GrcAchado {
  id          Int      @id @default(autoincrement())
  tenantId     Int
  auditoriaId  Int?
  riscoId      Int?
  controleId   Int?
  incidenteId  Int?
  criseId      Int?
  titulo       String
  descricao    String?
  gravidade    String
  statusAchado String
  causaRaiz    String?
  impactoResumo String?
  recomendacao String?
  ownerUserId  Int?
  prazoTratativaEm DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  auditoria    GrcAuditoria? @relation(fields: [auditoriaId], references: [id], onDelete: SetNull)
  risco        GrcRisco? @relation(fields: [riscoId], references: [id], onDelete: SetNull)
  controle     GrcControle? @relation(fields: [controleId], references: [id], onDelete: SetNull)
  owner        User?    @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)
  planosAcao   GrcPlanoAcao[]

  @@index([tenantId])
  @@index([tenantId, statusAchado])
  @@index([tenantId, gravidade])
}

model GrcPlanoAcao {
  id          Int      @id @default(autoincrement())
  tenantId     Int
  origemTipo   String
  origemId     Int
  titulo       String
  descricao    String?
  statusPlano  String
  criticidade  String
  ownerUserId  Int?
  aprovadorUserId Int?
  dataLimite   DateTime?
  concluidoEm  DateTime?
  resultadoEsperado String?
  criterioAceite String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner        User?    @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)
  aprovador    User?    @relation(fields: [aprovadorUserId], references: [id], onDelete: SetNull)
  itens        GrcPlanoAcaoItem[]
  evidencias   GrcEvidencia[]

  @@index([tenantId])
  @@index([tenantId, statusPlano])
}

model GrcPlanoAcaoItem {
  id          Int      @id @default(autoincrement())
  tenantId     Int
  planoAcaoId  Int
  ordemExecucao Int
  titulo       String
  descricao    String?
  statusItem   String
  responsavelUserId Int?
  dataLimite   DateTime?
  concluidoEm  DateTime?

  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  planoAcao    GrcPlanoAcao @relation(fields: [planoAcaoId], references: [id], onDelete: Cascade)
  responsavel  User?    @relation(fields: [responsavelUserId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([planoAcaoId])
  @@unique([planoAcaoId, ordemExecucao])
}

model GrcEvidencia {
  id          Int      @id @default(autoincrement())
  tenantId     Int
  referenciaTipo String
  referenciaId Int
  tipoEvidencia String
  titulo       String?
  descricao    String?
  arquivoPath  String?
  hashSha256   String?
  coletadoPor  Int?
  coletadoEm   DateTime @default(now())
  metadataJson Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  coletor      User?    @relation(fields: [coletadoPor], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, referenciaTipo, referenciaId])
}

model GrcControleMetrica {
  id          Int      @id @default(autoincrement())
  tenantId     Int
  controleId   Int
  chaveMetrica String
  bucketInicio DateTime
  bucketFim    DateTime
  valorNumero  Float?
  limiteAlerta Float?
  limiteCritico Float?
  statusMetrica String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  controle     GrcControle @relation(fields: [controleId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, chaveMetrica, bucketInicio])
}

model GrcMatrizRiscoSnapshot {
  id          Int      @id @default(autoincrement())
  tenantId     Int
  periodoRef  String
  categoriaRisco String
  quantidadeBaixo Int
  quantidadeMedio Int
  quantidadeAlto Int
  quantidadeCritico Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, periodoRef])
}
