datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Tenant {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique
  cnpj      String   @unique
  companyEmail String?
  companyWhatsapp String?
  link      String?
  googleMapsLink String?
  street    String?
  number    String?
  neighborhood String?
  city      String?
  state     String?
  cep       String?
  latitude  String?
  longitude String?
  status    String   @default("INACTIVE") // ACTIVE, INACTIVE (operacional)
  subscriptionStatus String @default("NONE") // NONE, TRIAL, ACTIVE, GRACE_PERIOD, EXPIRED (financeiro)
  trialEndsAt DateTime? // legado
  trialExpiresAt DateTime?
  paidUntil DateTime?
  gracePeriodEndsAt DateTime?
  billingProvider String?
  billingPlan String?
  billingExternalId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     TenantUser[]
  obras     Obra[]
  etapas    Etapa[]
  custos    Custo[]
  documentos Documento[]
  tarefas   Tarefa[]
  responsaveisTecnicos ResponsavelTecnico[]
  history   TenantHistoryEntry[]
  subscriptions Subscription[]
  unidades  Unidade[]
  funcionarios Funcionario[]
  organizacaoSetores OrganizacaoSetor[]
  organizacaoCargos OrganizacaoCargo[]
  organogramaPosicoes OrganogramaPosicao[]
  empresaRepresentantes EmpresaRepresentante[]
  empresaEncarregadosSistema EmpresaEncarregadoSistema[]
  perfis Perfil[]
  backupPoliticas BackupPoliticaTenant[]
  backupExecucoes BackupExecucaoTenant[]
  backupRestauracoes BackupRestauracaoTenant[]
  auditoriaEventos AuditoriaEvento[]
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  cpf       String   @unique
  name      String?
  password  String
  whatsapp  String?
  address   String?
  location  String?
  oauthProvider String?
  oauthId String?
  isSystemAdmin Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenants   TenantUser[]
  tenantHistoryEntries TenantHistoryEntry[]
  usuarioPerfis UsuarioPerfil[]
  usuarioAbrangencias UsuarioAbrangencia[]
  empresaEncarregadosSistema EmpresaEncarregadoSistema[]
  backupPoliticasConfiguradas BackupPoliticaTenant[]
  backupRestauracoesSolicitadas BackupRestauracaoTenant[]
  dashboardLayouts DashboardLayoutUsuario[]
  auditoriaEventos AuditoriaEvento[]
}

model TenantHistoryEntry {
  id        Int      @id @default(autoincrement())
  tenantId  Int
  source    String
  action    String?
  message   String
  actorUserId Int?
  createdAt DateTime @default(now())

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actorUser User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  attachments TenantHistoryAttachment[]

  @@index([tenantId])
  @@index([actorUserId])
}

model TenantHistoryAttachment {
  id      Int @id @default(autoincrement())
  entryId Int
  url     String?
  filename String?
  mimeType String?
  data     Bytes?

  entry   TenantHistoryEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@index([entryId])
}

model Subscription {
  id        Int      @id @default(autoincrement())
  tenantId  Int
  plan      String
  status    String
  startedAt DateTime
  expiresAt DateTime?
  paymentProvider String?
  paymentId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model TenantUser {
  id        Int      @id @default(autoincrement())
  tenantId  Int
  userId    Int
  role      String   @default("USER")
  login     String?
  ativo     Boolean  @default(true)
  bloqueado Boolean  @default(false)
  bloqueadoAteEm DateTime?
  tokenRevokedBefore DateTime?
  ultimoAcesso DateTime?
  funcionarioId Int?
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  funcionario Funcionario? @relation(fields: [funcionarioId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([tenantId, userId])
  @@unique([tenantId, login])
  @@index([userId])
  @@index([tenantId])
  @@index([funcionarioId])
}

model Obra {
  id        Int      @id @default(autoincrement())
  name      String
  description String?
  type      String   @default("PARTICULAR")
  status    String   @default("NAO_INICIADA")
  street       String?
  number       String?
  neighborhood String?
  city         String?
  state        String?
  latitude     String?
  longitude    String?
  valorPrevisto Decimal?
  tenantId  Int
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  etapas    Etapa[]
  custos    Custo[]
  documentos Documento[]
  tarefas   Tarefa[]
  medicoes  Medicao[]
  pagamentos Pagamento[]
  responsaveis ResponsavelObra[]
  usuarioAbrangencias UsuarioAbrangencia[]
  funcionarioLotacoes FuncionarioLotacao[]
  @@index([tenantId])
}

model Etapa {
  id        Int      @id @default(autoincrement())
  name      String
  obraId    Int
  obra      Obra     @relation(fields: [obraId], references: [id])
  tenantId  Int
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  startDate DateTime?
  endDate   DateTime?
  status    String   @default("PENDENTE")
  @@index([tenantId])
  @@index([obraId])
}

model Custo {
  id        Int      @id @default(autoincrement())
  description String
  amount    Decimal
  date      DateTime
  obraId    Int
  obra      Obra     @relation(fields: [obraId], references: [id])
  tenantId  Int
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  @@index([tenantId])
  @@index([obraId])
}

model Documento {
  id        Int      @id @default(autoincrement())
  name      String
  url       String
  type      String
  obraId    Int
  obra      Obra     @relation(fields: [obraId], references: [id])
  tenantId  Int
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  uploadedAt DateTime @default(now())
  versoes   DocumentoVersao[]
  @@index([tenantId])
  @@index([obraId])
}

model DocumentoVersao {
  id                         Int      @id @default(autoincrement())
  tenantId                    Int
  documentoId                 Int
  numeroVersao                Int      @default(1)
  urlOriginal                 String
  urlAssinado                 String?
  hashSha256Original          String?
  hashSha256Assinado          String?
  tipoAssinaturaFinal         String?
  assinaturaQualificadaConcluida Boolean @default(false)
  verificacaoAssinaturaStatus String?
  verificacaoAssinaturaEm     DateTime?
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  tenant                      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  documento                   Documento @relation(fields: [documentoId], references: [id], onDelete: Cascade)
  solicitacoesAssinatura      DocumentoAssinaturaSolicitacao[]

  @@unique([documentoId, numeroVersao])
  @@index([tenantId])
  @@index([documentoId])
}

model Tarefa {
  id        Int      @id @default(autoincrement())
  title     String
  description String?
  status    String   @default("PENDENTE")
  dueDate   DateTime?
  obraId    Int
  obra      Obra     @relation(fields: [obraId], references: [id])
  tenantId  Int
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  @@index([tenantId])
  @@index([obraId])
}

model ResponsavelTecnico {
  id        Int      @id @default(autoincrement())
  name      String
  professionalTitle String?
  crea      String?
  cpf       String?
  email     String?
  phone     String?
  tenantId  Int
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  obras     ResponsavelObra[]
  @@index([tenantId])
}

model ResponsavelObra {
  id        Int      @id @default(autoincrement())
  obraId    Int
  obra      Obra     @relation(fields: [obraId], references: [id])
  responsavelId Int
  responsavel ResponsavelTecnico @relation(fields: [responsavelId], references: [id])
  role      String
  startDate DateTime @default(now())
  endDate   DateTime?
  notes     String?
  @@index([obraId])
  @@index([responsavelId])
}

model Medicao {
  id        Int      @id @default(autoincrement())
  obraId    Int
  obra      Obra     @relation(fields: [obraId], references: [id])
  date      DateTime
  description String
  amount    Decimal
  percentage Decimal?
  createdAt DateTime @default(now())
  pagamentos Pagamento[]
  @@index([obraId])
}

model Pagamento {
  id        Int      @id @default(autoincrement())
  obraId    Int
  obra      Obra     @relation(fields: [obraId], references: [id])
  medicaoId Int?
  medicao   Medicao? @relation(fields: [medicaoId], references: [id])
  date      DateTime
  amount    Decimal
  documentNumber String?
  notes     String?
  createdAt DateTime @default(now())
  @@index([obraId])
  @@index([medicaoId])
}

// --- Sprint 0 (Fundação): Governança, Organograma, Funcionários, Backup e Dashboards ---

model Unidade {
  id         Int      @id @default(autoincrement())
  tenantId   Int
  codigo     String
  nome       String
  tipoUnidade String
  ativo      Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  funcionarioLotacoes FuncionarioLotacao[]
  usuarioAbrangencias UsuarioAbrangencia[]

  @@unique([tenantId, codigo])
  @@index([tenantId])
}

model Funcionario {
  id             Int      @id @default(autoincrement())
  tenantId       Int
  matricula      String
  nomeCompleto   String
  cpf            String
  email          String?
  telefone       String?
  cargo          String?
  funcaoPrincipal String?
  statusFuncional String  @default("ATIVO")
  dataAdmissao   DateTime?
  ativo          Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lotacoes       FuncionarioLotacao[]
  posicoes       FuncionarioPosicao[]
  usuarios       TenantUser[]
  representacoes EmpresaRepresentante[]
  encarregosSistema EmpresaEncarregadoSistema[]

  @@unique([tenantId, matricula])
  @@unique([tenantId, cpf])
  @@index([tenantId])
}

model FuncionarioLotacao {
  id           Int      @id @default(autoincrement())
  funcionarioId Int
  tipoLotacao  String
  obraId       Int?
  unidadeId    Int?
  dataInicio   DateTime
  dataFim      DateTime?
  atual        Boolean  @default(true)
  observacao   String?
  createdAt    DateTime @default(now())

  funcionario  Funcionario @relation(fields: [funcionarioId], references: [id], onDelete: Cascade)
  obra         Obra?       @relation(fields: [obraId], references: [id], onDelete: SetNull)
  unidade      Unidade?    @relation(fields: [unidadeId], references: [id], onDelete: SetNull)

  @@index([funcionarioId])
  @@index([obraId])
  @@index([unidadeId])
}

model OrganizacaoSetor {
  id         Int     @id @default(autoincrement())
  tenantId   Int
  nomeSetor  String
  tipoSetor  String
  setorPaiId Int?
  ativo      Boolean @default(true)

  tenant     Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  setorPai   OrganizacaoSetor? @relation("SetorPai", fields: [setorPaiId], references: [id], onDelete: SetNull)
  setoresFilhos OrganizacaoSetor[] @relation("SetorPai")
  posicoes   OrganogramaPosicao[]

  @@index([tenantId])
  @@index([setorPaiId])
}

model OrganizacaoCargo {
  id        Int     @id @default(autoincrement())
  tenantId  Int
  nomeCargo String
  ativo     Boolean @default(true)

  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  posicoes  OrganogramaPosicao[]

  @@unique([tenantId, nomeCargo])
  @@index([tenantId])
}

model OrganogramaPosicao {
  id            Int     @id @default(autoincrement())
  tenantId      Int
  setorId       Int
  cargoId       Int
  tituloExibicao String
  ativo         Boolean @default(true)

  tenant        Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  setor         OrganizacaoSetor @relation(fields: [setorId], references: [id], onDelete: Cascade)
  cargo         OrganizacaoCargo @relation(fields: [cargoId], references: [id], onDelete: Cascade)
  vinculosComoSuperior OrganogramaVinculo[] @relation("VinculoSuperior")
  vinculosComoSubordinada OrganogramaVinculo[] @relation("VinculoSubordinada")
  funcionarioPosicoes FuncionarioPosicao[]

  @@index([tenantId])
  @@index([setorId])
  @@index([cargoId])
}

model OrganogramaVinculo {
  id                  Int     @id @default(autoincrement())
  posicaoSuperiorId   Int
  posicaoSubordinadaId Int
  ativo               Boolean @default(true)

  posicaoSuperior     OrganogramaPosicao @relation("VinculoSuperior", fields: [posicaoSuperiorId], references: [id], onDelete: Cascade)
  posicaoSubordinada  OrganogramaPosicao @relation("VinculoSubordinada", fields: [posicaoSubordinadaId], references: [id], onDelete: Cascade)

  @@unique([posicaoSuperiorId, posicaoSubordinadaId])
  @@index([posicaoSuperiorId])
  @@index([posicaoSubordinadaId])
}

model FuncionarioPosicao {
  id           Int      @id @default(autoincrement())
  funcionarioId Int
  posicaoId    Int
  dataInicio   DateTime
  dataFim      DateTime?
  vigente      Boolean  @default(true)

  funcionario  Funcionario       @relation(fields: [funcionarioId], references: [id], onDelete: Cascade)
  posicao      OrganogramaPosicao @relation(fields: [posicaoId], references: [id], onDelete: Cascade)

  @@index([funcionarioId])
  @@index([posicaoId])
}

model EmpresaRepresentante {
  id               Int      @id @default(autoincrement())
  tenantId         Int
  funcionarioId    Int?
  nomeRepresentante String
  cpf              String
  email            String?
  ativo            Boolean  @default(true)
  dataInicio       DateTime
  dataFim          DateTime?

  tenant           Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  funcionario      Funcionario? @relation(fields: [funcionarioId], references: [id], onDelete: SetNull)
  encarregadosSistema EmpresaEncarregadoSistema[]

  @@index([tenantId])
  @@index([funcionarioId])
  @@index([cpf])
}

model EmpresaEncarregadoSistema {
  id                      Int      @id @default(autoincrement())
  tenantId                Int
  funcionarioId           Int
  userId                  Int?
  definidoPorRepresentanteId Int
  ativo                   Boolean  @default(true)
  dataInicio              DateTime
  dataFim                 DateTime?
  solicitouSaida          Boolean  @default(false)
  dataSolicitacaoSaida    DateTime?
  motivoSolicitacaoSaida  String?

  tenant                  Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  funcionario             Funcionario          @relation(fields: [funcionarioId], references: [id], onDelete: Cascade)
  user                    User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  definidoPorRepresentante EmpresaRepresentante @relation(fields: [definidoPorRepresentanteId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([funcionarioId])
  @@index([userId])
  @@index([definidoPorRepresentanteId])
}

model Perfil {
  id         Int      @id @default(autoincrement())
  tenantId   Int?
  tenantScope String
  tipoPerfil String
  codigo     String
  nome       String
  ativo      Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant     Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  permissoes PerfilPermissao[]
  usuarios   UsuarioPerfil[]

  @@unique([tenantScope, codigo])
  @@index([tenantId])
  @@index([tipoPerfil])
}

model PerfilPermissao {
  id        Int     @id @default(autoincrement())
  perfilId  Int
  modulo    String
  janela    String
  acao      String
  permitido Boolean @default(true)

  perfil    Perfil  @relation(fields: [perfilId], references: [id], onDelete: Cascade)

  @@index([perfilId])
  @@index([modulo])
}

model UsuarioPerfil {
  id       Int     @id @default(autoincrement())
  userId   Int
  perfilId Int
  ativo    Boolean @default(true)

  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  perfil   Perfil @relation(fields: [perfilId], references: [id], onDelete: Cascade)

  @@unique([userId, perfilId])
  @@index([userId])
  @@index([perfilId])
}

model UsuarioAbrangencia {
  id             Int     @id @default(autoincrement())
  userId         Int
  tipoAbrangencia String
  obraId         Int?
  unidadeId      Int?
  ativo          Boolean @default(true)

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  obra           Obra?    @relation(fields: [obraId], references: [id], onDelete: SetNull)
  unidade        Unidade? @relation(fields: [unidadeId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([obraId])
  @@index([unidadeId])
}

model BackupPoliticaTenant {
  id              Int      @id @default(autoincrement())
  tenantId        Int
  periodicidade   String
  horaExecucao    String
  diaSemana       Int?
  retencaoDias    Int      @default(30)
  ativo           Boolean  @default(true)
  configuradoPorUserId Int
  configuradoEm   DateTime @default(now())

  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  configuradoPor  User     @relation(fields: [configuradoPorUserId], references: [id], onDelete: Cascade)
  execucoes       BackupExecucaoTenant[]

  @@index([tenantId])
  @@index([configuradoPorUserId])
}

model BackupExecucaoTenant {
  id              Int      @id @default(autoincrement())
  politicaId      Int
  tenantId        Int
  dataHoraInicio  DateTime
  dataHoraFim     DateTime?
  status          String
  referenciaArquivo String?
  hashArquivo     String?
  observacao      String?

  politica        BackupPoliticaTenant @relation(fields: [politicaId], references: [id], onDelete: Cascade)
  tenant          Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([politicaId])
}

model BackupRestauracaoTenant {
  id             Int      @id @default(autoincrement())
  tenantId       Int
  pontoReferencia String
  motivo         String
  status         String
  solicitadoEm   DateTime @default(now())
  solicitadoPorUserId Int?

  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  solicitadoPor  User?    @relation(fields: [solicitadoPorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([solicitadoPorUserId])
  @@index([status])
}

model DashboardLayoutUsuario {
  id            Int     @id @default(autoincrement())
  userId        Int
  nomeLayout    String  @default("PADRAO")
  tipoDashboard String
  ativo         Boolean @default(true)

  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  widgets       DashboardWidgetUsuario[]

  @@index([userId])
  @@index([tipoDashboard])
}

model DashboardWidgetUsuario {
  id             Int     @id @default(autoincrement())
  layoutId       Int
  codigoWidget   String
  posicaoX       Int     @default(0)
  posicaoY       Int     @default(0)
  largura        Int     @default(4)
  altura         Int     @default(2)
  ativo          Boolean @default(true)

  layout         DashboardLayoutUsuario @relation(fields: [layoutId], references: [id], onDelete: Cascade)

  @@index([layoutId])
  @@index([codigoWidget])
}

model SecurityFieldPolicy {
  id                 Int      @id @default(autoincrement())
  tenantId            Int
  recurso             String
  acao                String
  caminhoCampo        String
  efeitoCampo         String
  estrategiaMascara   String?
  prioridade          Int      @default(0)
  condicaoJson        Json?
  ativo               Boolean  @default(true)
  criadoPorUserId     Int
  atualizadoPorUserId Int
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  criadoPor           User     @relation("SecurityFieldPolicyCriadoPor", fields: [criadoPorUserId], references: [id], onDelete: Cascade)
  atualizadoPor       User     @relation("SecurityFieldPolicyAtualizadoPor", fields: [atualizadoPorUserId], references: [id], onDelete: Cascade)
  alvos               SecurityFieldPolicyTarget[]

  @@index([tenantId])
  @@index([tenantId, recurso, acao])
  @@index([criadoPorUserId])
  @@index([atualizadoPorUserId])
}

model SecurityFieldPolicyTarget {
  id           Int      @id @default(autoincrement())
  policyId     Int
  tipoAlvo     String
  userId       Int?
  perfilCodigo String?
  permissao    String?
  ativo        Boolean  @default(true)
  createdAt    DateTime @default(now())

  policy       SecurityFieldPolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@index([policyId])
  @@index([tipoAlvo])
  @@index([userId])
  @@index([perfilCodigo])
}

model SecuritySensitiveDataAudit {
  id            Int      @id @default(autoincrement())
  tenantId      Int
  userId        Int
  recurso       String
  acao          String
  entidadeId    Int?
  caminhoCampo  String
  resultadoCampo String
  exportacao    Boolean  @default(false)
  motivoCodigo  String?
  contextoJson  Json?
  createdAt     DateTime @default(now())

  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, createdAt])
  @@index([tenantId, recurso, acao, createdAt])
}

model DocumentoAssinaturaProvedor {
  id         Int      @id @default(autoincrement())
  tenantId   Int
  nome       String
  codigo     String
  tipo       String
  ambiente   String   @default("SANDBOX")
  baseUrl    String
  clientId   String?
  clientSecretCriptografado String?
  apiKeyCriptografada String?
  configuracaoJson Json?
  ativo      Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  solicitacoes DocumentoAssinaturaSolicitacao[]

  @@unique([tenantId, codigo, ambiente])
  @@index([tenantId])
  @@index([tenantId, tipo])
}

model DocumentoAssinaturaSolicitacao {
  id                   Int      @id @default(autoincrement())
  tenantId             Int
  documentoId          Int
  versaoId             Int
  provedorId           Int
  tipoAssinatura       String
  statusSolicitacao    String   @default("RASCUNHO")
  providerEnvelopeId   String?
  providerDocumentId   String?
  providerStatus       String?
  exigeTodosSignatarios Boolean @default(true)
  callbackToken        String?
  linkAssinaturaExterno String?
  enviadoEm            DateTime?
  concluidoEm          DateTime?
  expiraEm             DateTime?
