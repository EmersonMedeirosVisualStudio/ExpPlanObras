  "main": "dist/server.js",
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "prisma:generate": "prisma generate --schema=./prisma/postgres/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema=./prisma/postgres/schema.prisma",
    "postinstall": "npm run prisma:generate",
    "create-system-admin": "npm run prisma:generate && tsx scripts/create-system-admin.ts",
    "seed-demo-tenants": "tsx scripts/seed-demo-tenants.ts",
    "build": "npm run prisma:generate && tsc",
    "start": "npm run prisma:migrate:deploy && node dist/server.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
