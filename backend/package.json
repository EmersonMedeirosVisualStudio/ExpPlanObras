    "@fastify/multipart": "^9.4.0",
    "@prisma/client": "^6.19.2",
    "@types/node": "^25.3.5",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.2",
    "fastify-type-provider-zod": "^6.1.0",
    "exceljs": "^4.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
