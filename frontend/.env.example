NEXT_PUBLIC_API_URL=http://localhost:3333

# Modes:
# - (empty) or "next": usa as rotas /api/* implementadas no próprio Next quando existirem; caso não exista, faz proxy para NEXT_PUBLIC_API_URL
# - "backend": força proxy de todas as rotas /api/* para o backend (não usa rotas /api/* do Next)
NEXT_PUBLIC_API_MODE=backend

# Se você for usar MySQL direto pelas rotas /api/v1 do Next (não recomendado na Vercel sem rede privada):
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=
